	<ItemTooltipPriceDisplayTierBonusPermille>90</ItemTooltipPriceDisplayTierBonusPermille>
	<!-- 展示价千分比上限（2300=最高 2.3×） -->
	<ItemTooltipPriceDisplayPermilleCap>2300</ItemTooltipPriceDisplayPermilleCap>

