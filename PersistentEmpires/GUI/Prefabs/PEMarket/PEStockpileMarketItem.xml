<Prefab>
  <Parameters>
    <Parameter Name="ItemDataSource" DefaultValue="" />
  </Parameters>
  <Constants>

  </Constants>
  <Window>
    <ButtonWidget DataSource="*ItemDataSource" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="PE.Market.ItemSlot" Command.Click="ExecuteSelect" Command.HoverBegin="ExecuteHoverStart" Command.HoverEnd="ExecuteHoverEnd" DoNotPassEventsToChildren="true" IsSelected="@IsSelected">
      <Children>
        <ListPanel MarginBottom="10" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="165" SuggestedHeight="70" HorizontalAlignment="Left" VerticalAlignment="Center" MarginBottom="10">
              <Children>
                <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Margin="-6" Sprite="StdAssets\frame_small" Color="@QualityGlowColor" />
                <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Margin="-2" Sprite="StdAssets\frame_small" Color="@QualityFrameColor" />
                <ImageIdentifierWidget HorizontalAlignment="Center" VerticalAlignment="Center" Id="ImageIdentifier" DataSource="{ImageIdentifier}" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="150" SuggestedHeight="60" ImageId="@Id" AdditionalArgs="@AdditionalArgs" ImageTypeCode="@ImageTypeCode" TextureProviderName="@TextureProviderName"></ImageIdentifierWidget>
              </Children>
            </Widget>
            <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="205" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" StackLayout.LayoutMethod="VerticalBottomToTop">
              <Children>
                <TextWidget Text="@ItemName" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="PE.SmallText.Default" />
                <TextWidget Text="@NineTierLine" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="2" Brush="PE.SmallText.Info" />
              </Children>
            </ListPanel>
            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" StackLayout.LayoutMethod="VerticalBottomToTop">
              <Children>
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <BrushWidget VerticalAlignment="Center" HorizontalAlignment="Right" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="50" SuggestedHeight="50" Sprite="SPGeneral\InventoryPartyExtension\Extension\gold_icon"></BrushWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" Brush="PE.Text.Success" IntText="@BuyPrice"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" Brush="PE.Text.Success" Text="@BuyLetterText"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" Text=" / "></TextWidget>
                    <BrushWidget VerticalAlignment="Center" HorizontalAlignment="Right" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="50" SuggestedHeight="50" Sprite="SPGeneral\InventoryPartyExtension\Extension\gold_icon"></BrushWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" Brush="PE.Text.Danger" IntText="@SellPrice"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" Brush="PE.Text.Danger" Text="@SellLetterText"></TextWidget>

                  </Children>
                </ListPanel>
                <ListPanel MarginLeft="100" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <TextWidget HorizontalAlignment="Center" Text="@StockPrefixText" Brush="PE.SmallText.Info" HeightSizePolicy="CoverChildren" WidthSizePolicy="CoverChildren"></TextWidget>
                    <TextWidget HorizontalAlignment="Center" MarginLeft="5" IntText="@Stock" Brush="PE.SmallText.Info" HeightSizePolicy="CoverChildren" WidthSizePolicy="CoverChildren"></TextWidget>
                  </Children>
                </ListPanel>
              </Children>
            </ListPanel>
          </Children>
        </ListPanel>
      </Children>
    </ButtonWidget>
  </Window>
</Prefab>