<Prefab>

  <Window>

    <Widget HorizontalAlignment="Center" VerticalAlignment="Center" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="1000" SuggestedHeight="580" MarginBottom="40">

      <Children>

        <Standard.Window Parameter.Title="@WindowTitle">

          <Children>

            <ListPanel MarginTop="52" MarginLeft="28" MarginRight="28" MarginBottom="20" StackLayout.LayoutMethod="VerticalTopToBottom" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">

              <Children>

                <ListPanel StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">

                  <Children>

                    <ImageIdentifierWidget DataSource="{Portrait}" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="268" SuggestedHeight="400" HorizontalAlignment="Left" VerticalAlignment="Top" AdditionalArgs="@AdditionalArgs" ImageId="@Id" ImageTypeCode="@ImageTypeCode" MarginRight="24" />

                    <ListPanel StackLayout.LayoutMethod="VerticalTopToBottom" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="4" VerticalAlignment="Top" HorizontalAlignment="Left">

                      <Children>

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="Stage.Title.Text" Brush.FontSize="24" Text="@NameCombatLine" MarginBottom="14" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" MarginBottom="4" Text="@FactionLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" MarginBottom="4" Text="@KnightOrderLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" MarginBottom="4" Text="@MilitaryLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" MarginBottom="4" Text="@NobleLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" MarginBottom="14" Text="@TitleLine" HorizontalAlignment="Left" />

                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="3" Sprite="GradientDivider_9" Color="#A18661FF" MarginBottom="12" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" Brush.FontColor="#E8DCC8FF" MarginBottom="4" Text="@CashLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" Brush.FontColor="#E8DCC8FF" MarginBottom="4" Text="@BankLine" HorizontalAlignment="Left" />

                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" Brush.FontColor="#E8DCC8FF" Text="@OtherCurrencyLine" HorizontalAlignment="Left" />

                      </Children>

                    </ListPanel>

                  </Children>

                </ListPanel>

                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="14" Brush.FontColor="#B8A88CFF" Text="@HintText" MarginTop="16" HorizontalAlignment="Center" />

              </Children>

            </ListPanel>

          </Children>

        </Standard.Window>

      </Children>

    </Widget>

  </Window>

</Prefab>

