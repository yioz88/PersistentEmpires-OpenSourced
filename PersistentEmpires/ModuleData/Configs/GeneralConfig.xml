	<!-- 角色最终生命上限 = 职业基础 + 首饰固定值 + 词条(3/32/42/99) + 同阶五件套加成，且不超过 PlayerMaxHealthTotalCap；入库读档亦钳制。 -->
	<PlayerMaxHealthTotalCap>1000000</PlayerMaxHealthTotalCap>
