	<EquipmentAffixArmorBonusCapPermille>350</EquipmentAffixArmorBonusCapPermille><!-- 词条护甲乘区额外上限，千分比（350=+35%） -->
	<MythicPreloadChancePermille>150</MythicPreloadChancePermille><!-- 神域·圣（显示品质 63）额外 15% 概率预埋神话词条槽；64+ 必出神话 -->
	<!-- 地面掉落光柱粒子（九阶 Band0–8；留空则用 ItemQualityHelper 默认：sparkle_a/b、blacksmith_flame、missile_flame、campfire） -->
	<LootBeamParticleBand0>psys_game_sparkle_a</LootBeamParticleBand0>
	<LootBeamParticleBand1>psys_game_sparkle_a</LootBeamParticleBand1>
	<LootBeamParticleBand2>psys_game_sparkle_a</LootBeamParticleBand2>
	<LootBeamParticleBand3>psys_game_sparkle_b</LootBeamParticleBand3>
	<LootBeamParticleBand4>psys_game_sparkle_b</LootBeamParticleBand4>
	<LootBeamParticleBand5>psys_game_blacksmith_flame</LootBeamParticleBand5>
	<LootBeamParticleBand6>psys_game_missile_flame</LootBeamParticleBand6>
	<LootBeamParticleBand7>psys_game_sparkle_b</LootBeamParticleBand7>
	<LootBeamParticleBand8>psys_game_campfire</LootBeamParticleBand8>
	<EquipmentSetBonusEnabled>true</EquipmentSetBonusEnabled><!-- 五件护甲同七阶带：翡翠生命+5%、苍蓝护甲+10%、紫晶挥砍/装填+15%、琥珀武器伤害+8%、赤血+5%、神域神话生命+10%与伤害+10%、太初五件 Lv35 生命+15%与伤害+15%（PlayerVitalityBonusHelper + PEAgentStatCalculateModel） -->
	<!-- 额外负重惩罚：有效护甲负重超过阈值时再乘移速（0=关闭；与原版耐力/重量公式叠加） -->
	<EquipmentEncumbranceExtraPenaltyEncumbranceThreshold>0</EquipmentEncumbranceExtraPenaltyEncumbranceThreshold>
	<EquipmentEncumbranceExtraPenaltySpeedPermillePerKOverThreshold>8</EquipmentEncumbranceExtraPenaltySpeedPermillePerKOverThreshold>

