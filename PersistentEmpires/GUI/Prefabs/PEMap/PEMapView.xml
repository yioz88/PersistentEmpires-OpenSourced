<Prefab>
  <Window>
    <NameMarkerScreenWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Brush.AlphaFactor="0" Brush.Color="#000000FF" TargetAlphaValue="0.0" MarkersContainer="MarkersContainer">
      <Children>

        <Widget Id="MarkersContainer" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" IsVisible="@IsActive">
          <Children>
            <Widget DataSource="{CastleMarkers}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
              <ItemTemplate>
                <PEMapCastleMarker />
              </ItemTemplate>
            </Widget>
            <PEMapPlayerMarker Parameter.ItemDataSource="{PlayerMapMarker}" />
          </Children>
        </Widget>

        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren" SuggestedWidth="360" HorizontalAlignment="Left" VerticalAlignment="Top" MarginLeft="28" MarginTop="28" IsVisible="@IsCastleTooltipVisible" Sprite="flat_panel_9" AlphaFactor="0.88">
          <Children>
            <ListPanel StackLayout.LayoutMethod="VerticalTopToBottom" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="16" MarginRight="16" MarginTop="12" MarginBottom="12">
              <Children>
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="Stage.Title.Text" Text="@CastleTooltipTitle" />
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="8" Brush="Kingdom.SortButtons.Text" Text="@CastleTooltipKnightOrders" />
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="4" Brush="Kingdom.SortButtons.Text" Text="@CastleTooltipPlayers" />
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="4" Brush="Kingdom.SortButtons.Text" Text="@CastleTooltipFaction" />
              </Children>
            </ListPanel>
          </Children>
        </Widget>
      </Children>
    </NameMarkerScreenWidget>
  </Window>
</Prefab>
