	<NewbieStarterPackEnabled>true</NewbieStarterPackEnabled>
	<NewbieStarterPackGold>5000</NewbieStarterPackGold>
	<!-- 格式 itemId:数量; 多条分号分隔 -->
	<NewbieStarterPackItems>PE_peasant_hatchet_1_t1:1;mp_tunic_with_shoulder_pads:1;mp_empire_horseman_boots:1;pe_kitchen_food_bread_a:5;pe_bandage:3;pe_book:1;pe_linen:20;pe_crude_iron:20;pe_wooden_plank:20</NewbieStarterPackItems>

	<!-- ===== 结构化聊天频道（LocalChatComponent / ConfigManager 冷却下限 500ms）===== -->
	<FactionChatEnabled>true</FactionChatEnabled>
	<KnightOrderChatEnabled>true</KnightOrderChatEnabled>
	<FamilyChatEnabled>true</FamilyChatEnabled>
	<ChatCooldownGlobalMs>3000</ChatCooldownGlobalMs>
	<ChatCooldownFactionMs>5000</ChatCooldownFactionMs>
	<ChatCooldownKnightOrderMs>10000</ChatCooldownKnightOrderMs>
	<ChatCooldownFamilyMs>8000</ChatCooldownFamilyMs>
	<ChatCooldownWhisperMs>2000</ChatCooldownWhisperMs>

	<!--
	  ===== 聊天命令前缀与颜色（ChatCommands）=====
	  MessagePrefix：命令前缀字符（如 /say）。
	  *Enabled：是否注册该命令；*Color：聊天中提示颜色（ARGB #AARRGGBB）。
	  Dice/Do/Me/Roll/Wounds：Distance = 附近可见距离（米）；Bubble = 是否在头顶气泡显示。
	  TeleportToPosition：管理员 !tp 类传送坐标命令。
	-->
	<MessagePrefix>/</MessagePrefix>
	<DefaultMessageColor>#FFFDFDFD</DefaultMessageColor>
	<AnnounceEnabled>true</AnnounceEnabled>
	<AnnounceColor>#FF0800FF</AnnounceColor>
	<CommandsEnabled>true</CommandsEnabled>
	<CommandsColor>#FFFDFDFD</CommandsColor>
	<DiceEnabled>true</DiceEnabled>
	<DiceColor>#FFFF6666</DiceColor>
	<DisableEnabled>true</DisableEnabled>
	<DisableColor>#FFFF6666</DisableColor>
	<DiceDistance>30</DiceDistance>
	<DiceBubble>true</DiceBubble>
	<DoEnabled>true</DoEnabled>
	<DoColor>#FFFF6666</DoColor>
	<DoDistance>30</DoDistance>
	<DoBubble>true</DoBubble>
	<HelpEnabled>true</HelpEnabled>
	<HelpColor>#FFFF6666</HelpColor>
	<MeEnabled>true</MeEnabled>
	<MeColor>#FFFF6666</MeColor>
	<MeDistance>30</MeDistance>
	<MeBubble>true</MeBubble>
	<MuteEnabled>true</MuteEnabled>
	<MuteColor>#FFFF6666</MuteColor>
	<NameEnabled>true</NameEnabled>
	<NameColor>#FFFF6666</NameColor>
	<RollEnabled>true</RollEnabled>
	<RollColor>#FFFF6666</RollColor>
	<RollDistance>30</RollDistance>
	<RollBubble>true</RollBubble>
	<VMuteEnabled>true</VMuteEnabled>
	<VmuteColor>#FFFF6666</VmuteColor>
	<WoundsEnabled>true</WoundsEnabled>
	<WoundsColor>#FFFF6666</WoundsColor>
	<WoundsDistance>0</WoundsDistance>
	<WoundsBubble>false</WoundsBubble>
	<TeleportToPositionColor>#FFFF6666</TeleportToPositionColor>
	<TeleportToPositionEnabled>true</TeleportToPositionEnabled>

	<!--
	  ===== ECO：星辉币兑换 / 在线点（节点名须与 ConfigManager 一致）=====
	  热更：① GameSettings 表 SettingKey=节点名；② 改 GeneralConfig.xml 后管理员 !reloadgeneralconfig。
	  汇率与手续费在客户端银行界面与 DBEcoCurrencyRepository 兑换逻辑中使用。
	  OnlinePoints*：在线点发放节奏（若服端行为已接 PersistEmpiresSave）；否则留作面板/后续版本。
	-->
	<CurrencyExchangeEnabled>true</CurrencyExchangeEnabled><!-- 是否允许在银行把星辉币换成口袋第纳尔 -->
	<CurrencyExchangeStellarToDenarRate>10000</CurrencyExchangeStellarToDenarRate><!-- 每单位星辉币对应基准第纳尔（扣费前） -->
	<CurrencyExchangeFeePercent>5</CurrencyExchangeFeePercent><!-- 手续费百分比 -->
	<CurrencyExchangeMinStellar>1</CurrencyExchangeMinStellar><!-- 单笔最少星辉币 -->
	<OnlinePointsGrantIntervalMinutes>60</OnlinePointsGrantIntervalMinutes>
	<OnlinePointsGrantPerTick>1</OnlinePointsGrantPerTick>
	<OnlinePointsDailyCap>240</OnlinePointsDailyCap>

	<!-- ===== Discord Webhook（DiscordBehavior）：默认关闭；填 Url 并 Enabled=true 生效 ===== -->
	<DiscordAdminMessageEnabled>false</DiscordAdminMessageEnabled><!-- 管理员相关通知 -->
	<DiscordAdminMessageUrl></DiscordAdminMessageUrl>
	<DiscordAnnounceEnabled>false</DiscordAnnounceEnabled><!-- 全服公告类 -->
	<DiscordAnnounceUrl></DiscordAnnounceUrl>
	<DiscordServeStatusEnabled>false</DiscordServeStatusEnabled><!-- 服务器状态心跳 -->
	<DiscordServeStatusUrl></DiscordServeStatusUrl>
	<DiscordExceptionEnabled>false</DiscordExceptionEnabled><!-- 未捕获异常告警 -->
	<DiscordExceptionUrl></DiscordExceptionUrl>
	<DiscordLogEnabled>false</DiscordLogEnabled><!-- 通用日志流水 -->
	<DiscordLogUrl></DiscordLogUrl>

	<!-- EquipmentAffixCombatBuffBehavior：词条链闪/灼烧DoT/定身与套装被动 Buff 标记（独立 BuffId，见 PeCombatBuffIds） -->
	<EquipmentAffixProcBuffsEnabled>true</EquipmentAffixProcBuffsEnabled>
	<EquipmentSetBonusBuffMarkersEnabled>true</EquipmentSetBonusBuffMarkersEnabled>
	<!-- 多人：专服广播 Buff 列表，客户端镜像供移速/承伤乘子与 UI（通用行：BuffId + Remaining + Power）；关闭则仅专服权威、客户端不同步 -->
	<EquipmentCombatBuffsNetworkSyncEnabled>true</EquipmentCombatBuffsNetworkSyncEnabled>
	<!-- 多人客户端：在两次同步之间本地递减 Remaining，供 HUD 倒计时平滑（权威仍以专服包为准）；关闭则仅在收到包时跳变 -->
	<EquipmentCombatBuffsClientHudRemainingSmooth>true</EquipmentCombatBuffsClientHudRemainingSmooth>

