<Prefab>
  <Constants>
    <Constant Name="TypingArea.Height" Value="40" />
    <Constant Name="TypingArea.Width" Value="350" />
  </Constants>

  <Window>
    <Widget HorizontalAlignment="Center" HeightSizePolicy="Fixed" VerticalAlignment="Center" WidthSizePolicy="Fixed" SuggestedHeight="500" SuggestedWidth="750" MarginBottom="50" MarginTop="50">
      <Children>
        <Standard.Window Parameter.Title="@WindowTitle">
          <Children>
            <ListPanel StackLayout.LayoutMethod="VerticalTopToBottom" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="12" MarginRight="12" MarginTop="8" MarginBottom="12">
              <Children>
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" MarginBottom="16" Brush="MPScoreboard.Info.Text" Text="@HotkeyHintText" />
                <ListPanel StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginBottom="12">
                  <Children>
                    <TextWidget VerticalAlignment="Center" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Text="@GoldInputLabelText"></TextWidget>
                    <Widget WidthSizePolicy="StretchToParent" VerticalAlignment="Center" HeightSizePolicy="Fixed" SuggestedHeight="55" MarginLeft="15" MarginRight="15" Sprite="StdAssets\Popup\text_input">
                      <Children>
                        <IntegerInputTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="ClanNaming.NameInput.Text" IntText="@GoldInput" GamepadNavigationIndex="0" />
                      </Children>
                    </Widget>
                  </Children>
                </ListPanel>
                <ListPanel StackLayout.LayoutMethod="VerticalTopToBottom" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="8">
                  <Children>
                    <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100" HorizontalAlignment="Center" Brush="WideButton.Flat" Command.Click="ExecuteDropMoney" IsEnabled="true" MarginBottom="12">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="25" Brush.TextVerticalAlignment="Center" Text="@DropMoneyButtonText" IsEnabled="true" />
                      </Children>
                    </ButtonWidget>
                    <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100" HorizontalAlignment="Center" Brush="WideButton.Flat" Command.Click="ExecuteRevealMoneyPouch" IsEnabled="true">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="25" Brush.TextVerticalAlignment="Center" Text="@RevealMoneyButtonText" IsEnabled="true" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </ListPanel>
              </Children>
            </ListPanel>
          </Children>
        </Standard.Window>

      </Children>
    </Widget>
  </Window>
</Prefab>
