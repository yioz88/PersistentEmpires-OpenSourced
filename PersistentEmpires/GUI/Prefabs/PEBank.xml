<Prefab>
  <Constants>
    <Constant Name="TypingArea.Height" Value="40" />
    <Constant Name="TypingArea.Width" Value="350" />
  </Constants>

  <Window>
    <Widget HorizontalAlignment="Center" HeightSizePolicy="Fixed" VerticalAlignment="Center" WidthSizePolicy="Fixed" SuggestedHeight="620" SuggestedWidth="750" MarginBottom="50" MarginTop="50">
      <Children>
        <Standard.Window Parameter.Title="@WindowTitle">
          <Children>
            <ListPanel StackLayout.LayoutMethod="VerticalBottomToTop" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
              <Children>
                <ListPanel MarginTop="65" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                  <Children>
                    <TextWidget VerticalAlignment="Center" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Text="@LabelAmount"></TextWidget>
                    <Widget WidthSizePolicy="StretchToParent" VerticalAlignment="Center" HeightSizePolicy="Fixed" SuggestedHeight="55" MarginLeft="15" MarginRight="15" Sprite="StdAssets\Popup\text_input">
                      <Children>
                        <IntegerInputTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="ClanNaming.NameInput.Text" IntText="@Amount" MaxInt="1000000" GamepadNavigationIndex="0" />
                      </Children>
                    </Widget>
                  </Children>
                </ListPanel>
                <ListPanel MarginTop="10" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                  <Children>
                    <TextWidget HorizontalAlignment="Center" WidthSizePolicy="CoverChildren" Brush.FontSize="28" HeightSizePolicy="CoverChildren" Text="@LabelBalancePrefix"></TextWidget>
                    <TextWidget HorizontalAlignment="Center" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Brush="PE.Text.Success" Brush.FontSize="28" MarginLeft="10" IntText="@Balance"></TextWidget>
                    <TextWidget HorizontalAlignment="Center" WidthSizePolicy="CoverChildren" Brush.FontSize="28" HeightSizePolicy="CoverChildren" MarginLeft="5" Text="@LabelDenar"></TextWidget>

                  </Children>
                </ListPanel>
				  <ListPanel MarginTop="10" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
					  <Children>
						  <TextWidget HorizontalAlignment="Left" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Brush="PE.Text.Danger" Brush.FontSize="20" MarginLeft="10" MarginTop="10" IntText="@TaxRate"></TextWidget>
						  <TextWidget HorizontalAlignment="Left" WidthSizePolicy="CoverChildren"  MarginTop="10" Brush="PE.Text.Danger" HeightSizePolicy="CoverChildren" Brush.FontSize="20" Text="@TaxRateSuffix"></TextWidget>
					  </Children>
				  </ListPanel>
                <ListPanel MarginTop="10" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                  <Children>
                    <TextWidget HorizontalAlignment="Left" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="22" Text="@StellarLineText" />
                  </Children>
                </ListPanel>
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" IsVisible="@ShowExchangeSection">
                  <Children>
                    <ListPanel StackLayout.LayoutMethod="VerticalBottomToTop" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="6">
                      <Children>
                        <TextWidget HorizontalAlignment="Left" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush.FontSize="18" Text="@ExchangeHintLine" />
                        <ListPanel MarginTop="8" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                          <Children>
                            <TextWidget VerticalAlignment="Center" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Text="@LabelExchangeAmount"></TextWidget>
                            <Widget WidthSizePolicy="StretchToParent" VerticalAlignment="Center" HeightSizePolicy="Fixed" SuggestedHeight="55" MarginLeft="15" MarginRight="15" Sprite="StdAssets\Popup\text_input">
                              <Children>
                                <IntegerInputTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="ClanNaming.NameInput.Text" IntText="@ExchangeStellarAmount" MaxInt="100000000" GamepadNavigationIndex="1" />
                              </Children>
                            </Widget>
                          </Children>
                        </ListPanel>
                        <ButtonWidget MarginTop="10" DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="90" HorizontalAlignment="Center" Brush="WideButton.Flat" Command.Click="ExecuteExchangeStellar" IsEnabled="true">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="23" Brush.TextVerticalAlignment="Center" Text="@ButtonExchange" IsEnabled="true" />
                          </Children>
                        </ButtonWidget>
                      </Children>
                    </ListPanel>
                  </Children>
                </Widget>
                <ListPanel StackLayout.LayoutMethod="VerticalBottomToTop" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="10">
                  <Children>
                    <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100"  HorizontalAlignment="Center" Brush="WideButton.Flat" Command.Click="ExecuteDeposit" IsEnabled="true">
                      <Children>
                        <TextWidget  WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="25" Brush.TextVerticalAlignment="Center" Text="@ButtonDeposit" IsEnabled="true" />
                      </Children>
                    </ButtonWidget>
                    <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100"  HorizontalAlignment="Center" Brush="WideButton.Flat" Command.Click="ExecuteWithdraw" IsEnabled="true">
                      <Children>
                        <TextWidget  WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="25" Brush.TextVerticalAlignment="Center" Text="@ButtonWithdraw" IsEnabled="true" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </ListPanel>
              </Children>
            </ListPanel>
          </Children>
        </Standard.Window>

      </Children>
    </Widget>
  </Window>
</Prefab>