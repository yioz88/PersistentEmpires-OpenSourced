<Prefab>
  <Constants>
    <Constant Name="TypingArea.Height" Value="40" />
    <Constant Name="TypingArea.Width" Value="350" />
  </Constants>

  <Window>
    <Widget HorizontalAlignment="Center" HeightSizePolicy="Fixed" VerticalAlignment="Top" WidthSizePolicy="Fixed" SuggestedHeight="320" SuggestedWidth="820" MarginBottom="50" MarginTop="50">
      <Children>

        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop">
          <Children>
            <TextWidget Text="@ChannelBanner" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="20" MarginBottom="8" Brush.FontSize="16" />
            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="12" MarginRight="12" MarginBottom="8" StackLayout.LayoutMethod="HorizontalLeftToRight">
              <Children>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteSelectProximity" IsSelected="@TabProximitySelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabNearText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteSelectWorld" IsSelected="@TabWorldSelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabWorldText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteSelectFaction" IsSelected="@TabFactionSelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabFactionText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteSelectOrder" IsSelected="@TabOrderSelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabOrderText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteSelectFamily" IsSelected="@TabFamilySelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabFamilyText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="100" SuggestedHeight="44" Brush="WideButton.Flat" Command.Click="ExecuteSelectWhisper" IsSelected="@TabWhisperSelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="16" Brush.TextVerticalAlignment="Center" Text="@TabWhisperText" />
                  </Children>
                </ButtonWidget>
              </Children>
            </ListPanel>
            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="12" MarginRight="12" MarginBottom="10" StackLayout.LayoutMethod="HorizontalLeftToRight">
              <Children>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="120" SuggestedHeight="40" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteRpToast">
                  <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="15" Brush.TextVerticalAlignment="Center" Text="@EmoteToastText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="120" SuggestedHeight="40" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteRpBow">
                  <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="15" Brush.TextVerticalAlignment="Center" Text="@EmoteBowText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="120" SuggestedHeight="40" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteRpNegotiate">
                  <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="15" Brush.TextVerticalAlignment="Center" Text="@EmoteNegotiateText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="120" SuggestedHeight="40" MarginRight="6" Brush="WideButton.Flat" Command.Click="ExecuteRpHire">
                  <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="15" Brush.TextVerticalAlignment="Center" Text="@EmoteHireText" />
                  </Children>
                </ButtonWidget>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="120" SuggestedHeight="40" Brush="WideButton.Flat" Command.Click="ExecuteRpBounty">
                  <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush.FontSize="15" Brush.TextVerticalAlignment="Center" Text="@EmoteBountyText" />
                  </Children>
                </ButtonWidget>
              </Children>
            </ListPanel>
            <Widget WidthSizePolicy="StretchToParent" VerticalAlignment="Center" HeightSizePolicy="Fixed" SuggestedHeight="55" MarginLeft="15" MarginRight="15" Sprite="StdAssets\Popup\text_input">
              <Children>
                <EditableTextWidget Id="EditableLocalChat" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="MP.ChatLog.Text" Text="@TextInput"  MarginLeft="15" MarginRight="15"   GamepadNavigationIndex="0" />
              </Children>
            </Widget>

          </Children>
        </ListPanel>

      </Children>
    </Widget>
  </Window>
</Prefab>
