	<EquipmentDurabilityLossOnHitPermille>2</EquipmentDurabilityLossOnHitPermille>
	<EquipmentDurabilityLossOnDeathPermille>80</EquipmentDurabilityLossOnDeathPermille>
	<EquipmentBrokenThresholdPermille>50</EquipmentBrokenThresholdPermille>
