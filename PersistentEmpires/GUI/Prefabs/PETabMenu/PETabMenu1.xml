<Prefab>
  <Constants>
    <Constant Name="NextButton.Width" BrushLayer="Default" BrushName="ButtonBrush1" BrushValueType="Width" />
    <Constant Name="NextButton.Height" BrushLayer="Default" BrushName="ButtonBrush1" BrushValueType="Height" />

    <Constant Name="PreviousButton.Width" BrushLayer="Default" BrushName="ButtonBrush2" BrushValueType="Width" />
    <Constant Name="PreviousButton.Height" BrushLayer="Default" BrushName="ButtonBrush2" BrushValueType="Height" />

    <Constant Name="ParallaxDuration" Value="6" />

    <Constant Name="Banner.Width" BrushLayer="Default" BrushName="PE.BannerButtonBrush" BrushValueType="Width" />
    <Constant Name="Banner.Height" BrushLayer="Default" BrushName="PE.BannerButtonBrush" BrushValueType="Height" />


    <Constant Name="Banner.Width.Scaled" MultiplyResult="0.80" Value="!Banner.Width" />
    <Constant Name="Banner.Height.Scaled" MultiplyResult="0.95" Value="!Banner.Height" />

  </Constants>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" IsVisible="@IsActive">
      <Children>
        <!-- 整板贴在屏幕底部；内部严格自上而下，避免 VerticalBottomToTop + Stretch 子项错位 -->
         <ListPanel StackLayout.LayoutMethod="VerticalBottomToTop" VerticalAlignment="Center" HorizontalAlignment="Center" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedHeight="900" SuggestedWidth="1450" Sprite="flat_panel_9" AlphaFactor="0.72">
          <Children>
            <!-- 顶部：阵营横幅 + 横向滚动条 -->
            <Widget MarginLeft="80" MarginRight="80" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
              <Children>
                <ListPanel MarginTop="10" MarginBottom="10" WidthSizePolicy="StretchToParent" StackLayout.LayoutMethod="VerticalTopToBottom" HeightSizePolicy="CoverChildren">
                  <Children>
                    <ScrollablePanel ClipRect="ClipContent" InnerPanel="ClipContent\FactionPanel" HorizontalScrollbar="..\HorizontalScrollbar" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                      <Children>
                        <Widget Id="ClipContent" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" ClipContents="true">
                          <Children>
                            <ListPanel Id="FactionPanel" DataSource="{Factions}" WidthSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight" HeightSizePolicy="CoverChildren" MarginTop="20" MarginLeft="90" MarginRight="90" HorizontalAlignment="Center">
                              <ItemTemplate>
                                <ButtonWidget Command.Click="ExecuteSelectFaction" IsSelected="@IsSelected" DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="110" SuggestedHeight="180" UpdateChildrenStates="true" GamepadNavigationIndex="0" MarginRight="50">
                                  <Children>
                                    <MaskedTextureWidget DataSource="{BannerImage}" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="125" SuggestedHeight="166" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PE.BannerButtonBrush" AdditionalArgs="@AdditionalArgs" ImageId="@Id" ImageTypeCode="@ImageTypeCode" />
                                    <BrushWidget Sprite="SPGeneral\MapOverlay\Encounter\WarIcon" HeightSizePolicy="Fixed" WidthSizePolicy="Fixed" HorizontalAlignment="Center" SuggestedHeight="70" SuggestedWidth="70" PositionYOffset="105" IsVisible="@ShowWarIcon"></BrushWidget>
                                  </Children>
                                </ButtonWidget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                    <ScrollbarWidget Id="HorizontalScrollbar" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="6" HorizontalAlignment="Center" MarginLeft="15" MarginRight="15" AlignmentAxis="Horizontal" Handle="HorizontalScrollbarHandle" MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="6" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" AlphaFactor="0.2" Color="#5a4033FF" />
                        <ImageWidget Id="HorizontalScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="10" MarginTop="1" MarginBottom="1" HorizontalAlignment="Center" Brush="FaceGen.Scrollbar.Handle" />
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </ListPanel>
              </Children>
            </Widget>

            <!-- 下方主体：自上而下 = 表头 → 统计 → 列表（占满剩余高度）→ 本机高亮 → 按键提示 -->
            <ListPanel StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100" MarginLeft="100" MarginRight="50">
              <Children>
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2" HorizontalAlignment="Center" MarginLeft="60" MarginTop="6" MarginRight="60" Sprite="GradientDivider_9" Color="#8B7355FF" />
                 <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" StackLayout.LayoutMethod="VerticalBottomToTop" MarginTop="20">
                  <Children>
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="33" SuggestedHeight="20" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextWidget MarginLeft="15" WidthSizePolicy="Fixed" SuggestedWidth="248" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="玩家" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="138" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="称号" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="军阶" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="爵位" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="兵种" />
                    <TextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="所属阵营" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="56" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@KillStreakColumnHeaderText" IsVisible="@ShowKillStreakScoreboardColumn" />
                    <TextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="96" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="延迟" />
                    <TextWidget MarginLeft="12" WidthSizePolicy="Fixed" SuggestedWidth="112" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="击败/阵亡" />
                    <Widget WidthSizePolicy="Fixed" SuggestedWidth="44" HeightSizePolicy="Fixed" />
                  </Children>
                </ListPanel>
                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="320" SuggestedHeight="2" HorizontalAlignment="Left" MarginLeft="100" MarginTop="2" Sprite="BlankWhiteSquare_9" Color="#E6C200FF" />
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="5" HorizontalAlignment="Center" MarginLeft="60" MarginRight="60" MarginTop="4" Sprite="BlankWhiteSquare_9" Color="#E6C200FF" />
                <ListPanel StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="100" MarginLeft="100" MarginRight="50">
                  <Children>
                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalTopToBottom" MarginTop="20" VerticalAlignment="Top">
                      <Children>
                        <TextWidget DataSource="{SelectedFaction}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@FactionName" Brush="Stage.Title.Text" />
                        <Widget DataSource="{SelectedFaction}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Top">
                          <Children>
                            <ListPanel DataSource="{Castles}" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="10" VerticalAlignment="Top">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginRight="15">
                                  <Children>
                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@CastleName" Brush="Kingdom.SortButtons.Text" />
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ListPanel>
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Text="本阵营" MarginRight="6" VerticalAlignment="Center"></TextWidget>
                    <TextWidget DataSource="{SelectedFaction}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" IntText="@MemberCount" VerticalAlignment="Center"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginLeft="3" MarginRight="3" Text="/" VerticalAlignment="Center"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" MarginRight="6" HeightSizePolicy="CoverChildren" IntText="@AllMemberCount" VerticalAlignment="Center"></TextWidget>
                    <TextWidget WidthSizePolicy="CoverChildren" MarginRight="40" HeightSizePolicy="CoverChildren" Text="人（全局）" VerticalAlignment="Center"></TextWidget>
                  </Children>
                </ListPanel>
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="5" HorizontalAlignment="Center" MarginLeft="60" MarginRight="60" MarginTop="2" Sprite="BlankWhiteSquare_9" Color="#E6C200FF" />

                <ListPanel StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="420" MarginLeft="80" MarginRight="72" MarginTop="4">
                  <Children>
                    <ScrollablePanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" AutoHideScrollBars="true" ClipRect="PeTabPlayerClip" InnerPanel="PeTabPlayerClip\PlayerList" VerticalScrollbar="..\PeTabPlayerVScroll">
                      <Children>
                        <Widget Id="PeTabPlayerClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                          <Children>
                            <ListPanel DataSource="{SelectedFactionMemberList}" Id="PlayerList" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalTopToBottom" VerticalAlignment="Top" HorizontalAlignment="Stretch" MarginRight="4">
                      <ItemTemplate>
                        <Widget Brush="PE.FactionLord" HeightSizePolicy="CoverChildren" WidthSizePolicy="StretchToParent" MarginTop="2" MarginBottom="2">
                          <Children>
                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="4" MarginRight="4" HorizontalAlignment="Left" VerticalAlignment="Top" MarginTop="4" StackLayout.LayoutMethod="HorizontalLeftToRight">
                              <Children>
                                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="33" SuggestedHeight="27" HorizontalAlignment="Left" VerticalAlignment="Center">
                                  <Children>
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="SPGeneral\SPScoreboard\leader_crown_icon" IsVisible="@IsLord" />
                                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="General\Icons\Army" IsVisible="@ShowMarshallIcon" />
                                  </Children>
                                </Widget>
                                <ScrollingTextWidget MarginLeft="15" WidthSizePolicy="Fixed" SuggestedWidth="248" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@UserName" />
                                <ScrollingTextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="138" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@RankTitleText" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@MilitaryRankText" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@NobleRankText" />
                                <Widget WidthSizePolicy="Fixed" SuggestedWidth="160" MarginLeft="6" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center">
                                  <Children>
                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="@CanSeeClass" Text="@UserClass" />
                                  </Children>
                                </Widget>
                                <ScrollingTextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@PlayerFactionDisplayName" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="56" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@KillStreakColumnText" IsVisible="@ShowKillStreakColumn" />
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="96" HeightSizePolicy="CoverChildren" MarginLeft="8" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget WidthSizePolicy="CoverChildren" MarginRight="4" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" IntText="@Ping" />
                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Text=" ms" />
                                  </Children>
                                </ListPanel>
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="112" HeightSizePolicy="CoverChildren" MarginLeft="12" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget IntText="@KillCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <TextWidget Text="/" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="3" MarginRight="3" />
                                    <TextWidget IntText="@DeathCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                  </Children>
                                </ListPanel>
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="44" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" MarginTop="5" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\mute_icon" Color="#F4E1C4FF" IsVisible="@IsVoiceMuted" Command.Click="ExecuteUnMute" />
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" MarginTop="5" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\unmute_icon" Color="#F4E1C4FF" IsHidden="@IsVoiceMuted" Command.Click="ExecuteMute" />
                                  </Children>
                                </ListPanel>
                              </Children>
                            </ListPanel>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" MarginLeft="4" MarginTop="2" SuggestedHeight="3" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Sprite="MPGeneral\MPScoreboard\player_indicator" AlphaFactor="0.28" />
                          </Children>
                        </Widget>
                      </ItemTemplate>
                    </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                    <ScrollbarWidget Id="PeTabPlayerVScroll" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="10" HorizontalAlignment="Right" VerticalAlignment="Stretch" MarginLeft="4" AlignmentAxis="Vertical" Handle="PeTabPlayerVScrollHandle" MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#5a4033FF" AlphaFactor="0.2" />
                        <ImageWidget Id="PeTabPlayerVScrollHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedHeight="10" SuggestedWidth="8" HorizontalAlignment="Center" Brush="FaceGen.Scrollbar.Handle" />
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </ListPanel>

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" IsVisible="@HasLocalPlayerHighlight" ClipContents="true">
                  <Children>
                    <ListPanel DataSource="{LocalPlayerHighlight}" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="72" MarginLeft="80" MarginRight="80" MarginTop="4" HorizontalAlignment="Center" ClipContents="true">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="33" SuggestedHeight="27" HorizontalAlignment="Left" VerticalAlignment="Center">
                          <Children>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="SPGeneral\SPScoreboard\leader_crown_icon" IsVisible="@IsLord" />
                            <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="General\Icons\Army" IsVisible="@ShowMarshallIcon" />
                          </Children>
                        </Widget>
                        <ScrollingTextWidget MarginLeft="15" WidthSizePolicy="Fixed" SuggestedWidth="248" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@UserName" />
                        <ScrollingTextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="138" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@RankTitleText" />
                        <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@MilitaryRankText" />
                        <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@NobleRankText" />
                        <Widget WidthSizePolicy="Fixed" SuggestedWidth="160" MarginLeft="6" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="@CanSeeClass" Text="@UserClass" />
                          </Children>
                        </Widget>
                        <ScrollingTextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@PlayerFactionDisplayName" />
                        <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="56" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@KillStreakColumnText" IsVisible="@ShowKillStreakColumn" />
                        <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="96" HeightSizePolicy="CoverChildren" MarginLeft="8" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                          <Children>
                            <TextWidget WidthSizePolicy="CoverChildren" MarginRight="4" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" IntText="@Ping" />
                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Text=" ms" />
                          </Children>
                        </ListPanel>
                        <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="112" HeightSizePolicy="CoverChildren" MarginLeft="12" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                          <Children>
                            <TextWidget IntText="@KillCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextWidget Text="/" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="3" MarginRight="3" />
                            <TextWidget IntText="@DeathCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                          </Children>
                        </ListPanel>
                        <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="44" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                          <Children>
                            <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" MarginTop="5" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\mute_icon" Color="#F4E1C4FF" IsVisible="@IsVoiceMuted" Command.Click="ExecuteUnMute" />
                            <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" MarginTop="5" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\unmute_icon" Color="#F4E1C4FF" IsHidden="@IsVoiceMuted" Command.Click="ExecuteMute" />
                          </Children>
                        </ListPanel>
                      </Children>
                    </ListPanel>
                  </Children>
                </Widget>

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="56" HorizontalAlignment="Center" MarginTop="4" MarginBottom="4" IsHidden="@IsMouseEnabled">
                  <Children>
                    <ListPanel DataSource="{ShowMouseKey}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalTopToBottom" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Children>
                        <InputKeyVisualWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="44" SuggestedHeight="44" VerticalAlignment="Center" HorizontalAlignment="Center" Color="#F4E1C4FF" KeyID="@KeyID"/>
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="MPScoreboard.Info.Text" Text="@KeyName" />
                      </Children>
                    </ListPanel>
                  </Children>
                </Widget>
              </Children>
            </ListPanel>
          </Children>

        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
