<Prefab>
  <Constants>

  </Constants>

  <Window>
    <Widget HorizontalAlignment="Center" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" IsVisible="@IsActive">
      <Children>
        <ListPanel StackLayout.LayoutMethod="VerticalTopToBottom" HorizontalAlignment="Center" WidthSizePolicy="CoverChildren" MarginTop="20" HeightSizePolicy="CoverChildren">
          <Children>
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginBottom="6" Brush="MPScoreboard.Info.Text" Text="@RespawnCountdownLine" />
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginBottom="6" Brush="MPScoreboard.Info.Text" Text="@ControlsHintLine" />
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginBottom="6" IsVisible="@ShowRespawnGenderHint" Brush="MPScoreboard.Info.Text" Text="@RespawnGenderHintLine" />
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginBottom="6" IsVisible="@ShowRespawnGenderHint" Brush="MPScoreboard.Info.Text" Text="@RespawnGenderStatusLine" />
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginBottom="6" IsVisible="@ShowReviveCoinHint" Text="@ReviveHintLine" />
            <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true" WidthSizePolicy="Fixed" SuggestedWidth="360" HeightSizePolicy="Fixed" SuggestedHeight="48" HorizontalAlignment="Center" MarginTop="4" MarginBottom="8" Brush="WideButton.Flat" Command.Click="ExecuteInstantRevive" IsVisible="@ShowInstantReviveButton" IsEnabled="@CanInstantRevive">
              <Children>
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPLobby.PlayButton.Text" Brush.FontSize="20" Brush.TextVerticalAlignment="Center" Text="@InstantReviveButtonText" />
              </Children>
            </ButtonWidget>
            <TextWidget WidthSizePolicy="CoverChildren" HorizontalAlignment="Center" HeightSizePolicy="CoverChildren" MarginTop="4" Brush="MPScoreboard.Info.Text" Text="@SpawnPlaceLine" />
          </Children>
        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
