<Prefab>
  <Constants>
    <Constant Name="NextButton.Width" BrushLayer="Default" BrushName="ButtonBrush1" BrushValueType="Width" />
    <Constant Name="NextButton.Height" BrushLayer="Default" BrushName="ButtonBrush1" BrushValueType="Height" />

    <Constant Name="PreviousButton.Width" BrushLayer="Default" BrushName="ButtonBrush2" BrushValueType="Width" />
    <Constant Name="PreviousButton.Height" BrushLayer="Default" BrushName="ButtonBrush2" BrushValueType="Height" />

    <Constant Name="ParallaxDuration" Value="6" />

    <Constant Name="Banner.Width" BrushLayer="Default" BrushName="PE.BannerButtonBrush" BrushValueType="Width" />
    <Constant Name="Banner.Height" BrushLayer="Default" BrushName="PE.BannerButtonBrush" BrushValueType="Height" />


    <Constant Name="Banner.Width.Scaled" MultiplyResult="0.80" Value="!Banner.Width" />
    <Constant Name="Banner.Height.Scaled" MultiplyResult="0.95" Value="!Banner.Height" />

  </Constants>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" IsVisible="@IsActive">
      <Children>
        <!-- 整板贴底：VerticalBottomToTop → 列表末项在屏幕上方（旗帜顶），列表首项在下方（计分主体） -->
        <ListPanel StackLayout.LayoutMethod="VerticalBottomToTop" VerticalAlignment="Bottom" MarginBottom="40" HorizontalAlignment="Center" WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren" SuggestedWidth="1560" Sprite="flat_panel_9" AlphaFactor="0.82">
          <Children>
            <!-- ⑥ 计分板主体（自下而上：鼠标 → 玩家 → 细线 → 列标题 → 黄线 → 阵营信息） -->
            <ListPanel Id="PeTabScoreboardBody" StackLayout.LayoutMethod="VerticalBottomToTop" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="0" MarginRight="0" MarginTop="8" MarginBottom="5">
              <Children>
                <Widget Id="PeTabMouseHint" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="56" HorizontalAlignment="Center" MarginTop="4" MarginBottom="4" IsHitTestVisible="false" IsHidden="@IsMouseEnabled">
                  <Children>
                    <ListPanel DataSource="{ShowMouseKey}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Children>
                        <InputKeyVisualWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="44" SuggestedHeight="44" VerticalAlignment="Center" HorizontalAlignment="Center" Color="#F4E1C4FF" KeyID="@KeyID"/>
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="MPScoreboard.Info.Text" Text="@KeyName" />
                      </Children>
                    </ListPanel>
                  </Children>
                </Widget>

                <Widget Id="PeTabPlayerRowsHost" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="360" MarginLeft="72" MarginRight="72" MarginTop="6" MarginBottom="4" Sprite="BlankWhiteSquare_9" Color="#1A1410FF" AlphaFactor="0.35">
                  <Children>
                    <ScrollablePanel Id="PeTabPlayerScroll" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" AutoHideScrollBars="false" MarginLeft="8" MarginRight="8" MarginTop="6" MarginBottom="6" ClipRect="PeTabPlayerClip" InnerPanel="PeTabPlayerClip\PeTabFactionPlayerList" VerticalScrollbar="..\PeTabPlayerVScroll">
                      <Children>
                        <Widget Id="PeTabPlayerClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                          <Children>
                            <ListPanel DataSource="{SelectedFactionMemberList}" Id="PeTabFactionPlayerList" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop" VerticalAlignment="Top" HorizontalAlignment="Left">
                              <ItemTemplate>
                                <Widget HeightSizePolicy="CoverChildren" WidthSizePolicy="StretchToParent" MarginTop="1" MarginBottom="1">
                                  <Children>
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#F4E1C4FF" AlphaFactor="0.06" />
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="1" VerticalAlignment="Bottom" Sprite="BlankWhiteSquare_9" Color="#C8B89AFF" AlphaFactor="0.25" />
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="8" MarginRight="8" HorizontalAlignment="Left" VerticalAlignment="Center" MarginTop="4" MarginBottom="4" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                      <Children>
                                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="33" SuggestedHeight="27" HorizontalAlignment="Left" VerticalAlignment="Center">
                                  <Children>
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="SPGeneral\SPScoreboard\leader_crown_icon" IsVisible="@IsLord" />
                                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="General\Icons\Army" IsVisible="@ShowMarshallIcon" />
                                  </Children>
                                </Widget>
                                <ScrollingTextWidget MarginLeft="15" WidthSizePolicy="Fixed" SuggestedWidth="248" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="MPScoreboard.Player.Name.Text" Text="@UserName" />
                                <ScrollingTextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="138" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@RankTitleText" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@MilitaryRankText" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@NobleRankText" />
                                <Widget WidthSizePolicy="Fixed" SuggestedWidth="160" MarginLeft="6" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center">
                                  <Children>
                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="@CanSeeClass" Text="@UserClass" />
                                  </Children>
                                </Widget>
                                <ScrollingTextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@PlayerFactionDisplayName" />
                                <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="56" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="Kingdom.SortButtons.Text" Text="@KillStreakColumnText" IsVisible="@ShowKillStreakColumn" />
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="96" HeightSizePolicy="CoverChildren" MarginLeft="8" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget WidthSizePolicy="CoverChildren" MarginRight="4" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" IntText="@Ping" />
                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" Text=" ms" />
                                  </Children>
                                </ListPanel>
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="112" HeightSizePolicy="CoverChildren" MarginLeft="12" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget IntText="@KillCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <TextWidget Text="/" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="3" MarginRight="3" />
                                    <TextWidget IntText="@DeathCount" WidthSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                  </Children>
                                </ListPanel>
                                <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="44" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\mute_icon" Color="#F4E1C4FF" IsVisible="@IsVoiceMuted" Command.Click="ExecuteUnMute" />
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="20" SuggestedHeight="20" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="MPGeneral\MPScoreboard\unmute_icon" Color="#F4E1C4FF" IsHidden="@IsVoiceMuted" Command.Click="ExecuteMute" />
                                  </Children>
                                </ListPanel>
                                      </Children>
                                    </ListPanel>
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                    <ScrollbarWidget Id="PeTabPlayerVScroll" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="8" HorizontalAlignment="Right" MarginRight="2" MarginTop="8" MarginBottom="8" AlignmentAxis="Vertical" Handle="PeTabPlayerVScrollHandle" MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" AlphaFactor="0.15" Color="#5a4033FF" />
                        <ImageWidget Id="PeTabPlayerVScrollHandle" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="48" HorizontalAlignment="Center" MarginLeft="1" MarginRight="1" Brush="FaceGen.Scrollbar.Handle" />
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </Widget>

                <Widget Id="PeTabLineThin" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="1" HorizontalAlignment="Center" MarginLeft="72" MarginRight="72" MarginTop="6" MarginBottom="2" Sprite="BlankWhiteSquare_9" Color="#C8B89AFF" AlphaFactor="0.65" />

                <Widget Id="PeTabColumnHeaders" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="38" MarginLeft="72" MarginRight="72" MarginTop="4" Sprite="BlankWhiteSquare_9" Color="#2A221AFF" AlphaFactor="0.55">
                  <Children>
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginLeft="8" MarginRight="8" StackLayout.LayoutMethod="HorizontalLeftToRight" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <Children>
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="33" SuggestedHeight="20" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextWidget MarginLeft="15" WidthSizePolicy="Fixed" SuggestedWidth="248" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@StatsPlayersLabelHeaderText" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="138" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderRankTitleText" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderMilitaryRankText" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="78" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderNobleRankText" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderClassText" />
                    <TextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderFactionText" />
                    <TextWidget MarginLeft="6" WidthSizePolicy="Fixed" SuggestedWidth="56" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@KillStreakColumnHeaderText" IsVisible="@ShowKillStreakScoreboardColumn" />
                    <TextWidget MarginLeft="8" WidthSizePolicy="Fixed" SuggestedWidth="96" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderPingText" />
                    <TextWidget MarginLeft="12" WidthSizePolicy="Fixed" SuggestedWidth="112" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Center" Brush="MPScoreboard.Header.Text" Text="@HeaderKdText" />
                    <Widget WidthSizePolicy="Fixed" SuggestedWidth="44" HeightSizePolicy="Fixed" />
                  </Children>
                </ListPanel>
                  </Children>
                </Widget>

                <Widget Id="PeTabLineYellow" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="6" HorizontalAlignment="Center" MarginLeft="48" MarginRight="48" MarginTop="6" MarginBottom="2" Sprite="BlankWhiteSquare_9" Color="#E6C200FF" AlphaFactor="0.95" />

                <ListPanel Id="PeTabFactionFooter" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="100" MarginRight="80" MarginTop="4" MarginBottom="2" VerticalAlignment="Top">
                  <Children>
                    <ListPanel Id="PeTabFactionLeftColumn" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop" VerticalAlignment="Top" HorizontalAlignment="Left">
                      <Children>
                        <TextWidget DataSource="{SelectedFaction}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Top" Text="@FactionName" Brush="Stage.Title.Text" />
                        <Widget Id="PeTabLineBrownShort" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="880" SuggestedHeight="2" HorizontalAlignment="Left" MarginTop="4" MarginBottom="6" Sprite="GradientDivider_9" Color="#8B7355FF" AlphaFactor="0.9" />
                        <Widget DataSource="{SelectedFaction}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Top" HorizontalAlignment="Left">
                          <Children>
                            <ListPanel DataSource="{Castles}" StackLayout.LayoutMethod="HorizontalLeftToRight" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="6" VerticalAlignment="Top">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginRight="15">
                                  <Children>
                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Center" Text="@CastleName" Brush="Kingdom.SortButtons.Text" />
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ListPanel>
                    <ListPanel Id="PeTabFactionMemberCount" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight" HorizontalAlignment="Right" VerticalAlignment="Top" MarginLeft="12" MarginTop="2">
                      <Children>
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Text="@FactionMembersLabelText" MarginRight="6" VerticalAlignment="Center" />
                        <TextWidget DataSource="{SelectedFaction}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" IntText="@MemberCount" VerticalAlignment="Center" />
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginLeft="3" MarginRight="3" Text="/" VerticalAlignment="Center" />
                        <TextWidget WidthSizePolicy="CoverChildren" MarginRight="6" HeightSizePolicy="CoverChildren" IntText="@AllMemberCount" VerticalAlignment="Center" />
                        <TextWidget WidthSizePolicy="CoverChildren" MarginRight="40" HeightSizePolicy="CoverChildren" Text="@FactionMembersSuffixText" VerticalAlignment="Center" />
                      </Children>
                    </ListPanel>
                  </Children>
                </ListPanel>
              </Children>
            </ListPanel>

            <!-- ① 顶部：阵营旗帜 + 横向滚动条（列表末项 = 屏幕上方） -->
            <Widget MarginLeft="80" MarginRight="80" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="210">
              <Children>
                <ListPanel MarginTop="10" MarginBottom="10" WidthSizePolicy="StretchToParent" StackLayout.LayoutMethod="VerticalBottomToTop" HeightSizePolicy="CoverChildren">
                  <Children>
                    <ScrollablePanel ClipRect="ClipContent" InnerPanel="ClipContent\FactionPanel" HorizontalScrollbar="..\HorizontalScrollbar" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="200">
                      <Children>
                        <Widget Id="ClipContent" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="190" ClipContents="true">
                          <Children>
                            <ListPanel Id="FactionPanel" DataSource="{Factions}" WidthSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight" HeightSizePolicy="CoverChildren" MarginTop="20" MarginLeft="90" MarginRight="90" HorizontalAlignment="Center">
                              <ItemTemplate>
                                <ButtonWidget Command.Click="ExecuteSelectFaction" IsSelected="@IsSelected" DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="110" SuggestedHeight="180" UpdateChildrenStates="true" MarginRight="50" GamepadNavigationIndex="0">
                                  <Children>
                                    <MaskedTextureWidget DataSource="{BannerImage}" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="125" SuggestedHeight="166" HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PE.BannerButtonBrush" AdditionalArgs="@AdditionalArgs" ImageId="@Id" ImageTypeCode="@ImageTypeCode" TextureProviderName="@TextureProviderName" />
                                    <BrushWidget Sprite="SPGeneral\MapOverlay\Encounter\WarIcon" HeightSizePolicy="Fixed" WidthSizePolicy="Fixed" HorizontalAlignment="Center" SuggestedHeight="70" SuggestedWidth="70" PositionYOffset="105" IsVisible="@ShowWarIcon"></BrushWidget>
                                  </Children>
                                </ButtonWidget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                    <ScrollbarWidget Id="HorizontalScrollbar" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="6" HorizontalAlignment="Center" MarginLeft="15" MarginRight="15" AlignmentAxis="Horizontal" Handle="HorizontalScrollbarHandle" MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="6" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" AlphaFactor="0.2" Color="#5a4033FF" />
                        <ImageWidget Id="HorizontalScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="10" MarginTop="1" MarginBottom="1" HorizontalAlignment="Center" Brush="FaceGen.Scrollbar.Handle" />
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </ListPanel>
              </Children>
            </Widget>
          </Children>

        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
