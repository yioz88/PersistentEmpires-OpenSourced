<Prefab>
  <Constants>
    <Constant Name="PowerBar.Flag.Width" BrushLayer="Default" BrushName="MPHUD.PowerBar.Flag"
      BrushValueType="Width" />
    <Constant Name="PowerBar.Flag.Height" BrushLayer="Default" BrushName="MPHUD.PowerBar.Flag"
      BrushValueType="Height" />

    <Constant Name="Flag.Identifier.Dimension" Value="40" />
  </Constants>
  <Window>
    <MultiplayerMissionMarkerListPanel WidthSizePolicy="CoverChildren"
      HeightSizePolicy="CoverChildren" Distance="@Distance"
      FarAlphaTarget="0.22" FarDistanceCutoff="52" IsMarkerEnabled="true"
      StackLayout.LayoutMethod="VerticalTopToBottom" MarkerType="@MarkerType"
      PeerWidget="PeerWidget" Position="@ScreenPosition" IsSpawnFlag="false">
      <Children>
        <Widget Id="PeerWidget" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
          HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="@IsMarkerShellVisible">
          <Children>
            <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
              HorizontalAlignment="Center" StackLayout.LayoutMethod="VerticalTopToBottom">
              <Children>
                <ListPanel DataSource="{ChatMessages}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                  StackLayout.LayoutMethod="VerticalTopToBottom" MarginBottom="8">
                  <ItemTemplate>
                    <TextWidget Id="NameTextWidget" WidthSizePolicy="Fixed" SuggestedWidth="400"
                      HeightSizePolicy="CoverChildren" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush" ClipContents="false" Brush.FontColor="@Color" Brush.FontSize="@FontSize"
                      OverrideDefaultStateSwitchingEnabled="true" Text="@Message" MarginTop="3" />
                  </ItemTemplate>
                </ListPanel>
                <!-- Vertical stack: plain Widget siblings default to horizontal → one crowded row. -->
                <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                  HorizontalAlignment="Center" StackLayout.LayoutMethod="VerticalTopToBottom">
                  <Children>
                    <!-- Order: title → knight order → faction → name → ranks → power -->
                    <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                      ClipContents="false" Brush.FontColor="#FFD700FF" Brush.FontSize="@TitleFontSize"
                      Text="@TitleLineText" IsVisible="@IsTitleVisible" MarginBottom="8" />
                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                  ClipContents="false" Brush.FontColor="#FFE082FF" Brush.FontSize="@TitleFontSize"
                  Text="@KnightOrderLineText" IsVisible="@IsKnightOrderLineVisible" MarginBottom="8" />
                    <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                      ClipContents="false" Brush.FontColor="#A5D6A7FF" Brush.FontSize="@FactionFontSize"
                      Text="@FactionLineText" IsVisible="@IsFactionLineVisible" MarginBottom="8" />
                    <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                      ClipContents="false" Brush.FontColor="#FFFFFFFF" Brush.FontSize="@NameFontSize"
                      Text="@NameLineText" MarginBottom="10" />
                    <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                      ClipContents="false" Brush.FontColor="#9B59B6FF" Brush.FontSize="@RankFontSize"
                      Text="@NobleRankLineText" IsVisible="@IsNobleLineVisible" MarginBottom="6" />
                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                  ClipContents="false" Brush.FontColor="#E74C3CFF" Brush.FontSize="@RankFontSize"
                  Text="@MilitaryRankLineText" IsVisible="@IsMilitaryLineVisible" MarginBottom="8" />
                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                  ClipContents="false" Brush.FontColor="#00E5FFFF" Brush.FontSize="@PowerFontSize"
                  Text="@KillStreakLineText" IsVisible="@IsKillStreakLineVisible" MarginBottom="6" />
                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="440" HeightSizePolicy="CoverChildren"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Brush="PEPeerMarker.TextBrush"
                  ClipContents="false" Brush.FontColor="#FFCC00FF" Brush.FontSize="@PowerFontSize"
                  Text="@CombatPowerText" IsVisible="@IsPowerLineVisible" MarginBottom="6" />
                  </Children>
                </ListPanel>
              </Children>
            </ListPanel>
          </Children>
        </Widget>
      </Children>
    </MultiplayerMissionMarkerListPanel>
  </Window>
</Prefab>
